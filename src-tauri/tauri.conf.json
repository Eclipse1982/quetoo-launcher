{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quetoo Launcher",
  "version": "0.6.0",
  "identifier": "org.eclipse.quetoolauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quetoo Launcher",
        "width": 920,
        "height": 700,
        "resizable": true,
        "minWidth": 640,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyREY3NzYzQ0YxRTlCODEKUldTQm14N1BZM2ZmSXBzVmt0UlhqbjV2dW93QkNBT0dZKzNPR0xqb2VMbmFkUWpBSWl4S211bUEK",
      "endpoints": [
        "https://github.com/Eclipse1982/quetoo-launcher-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
